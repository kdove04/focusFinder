# Required in production. In local dev, a built-in fallback is used until you set this.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Microsoft Entra ID (Azure AD) app — see README “Sign-in (JSU Microsoft 365)”
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Single-tenant JSU: https://login.microsoftonline.com/<Directory (tenant) ID>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# Optional: comma-separated allowed email domains (default: students.jsums.edu only)
# ALLOWED_EMAIL_DOMAINS=students.jsums.edu,jsums.edu
